      "updated": 1778977037220,
      "link": null,
      "locked": false,
      "text": "Upload large files (50gb)\n50 GB @ 100 mbps = 1h 12 mins\n\nmultipart upload=> \nchunk files on client to 5mb chunk\n\nfingerprint each chunk: hash(bytes)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Upload large files (50gb)\n50 GB @ 100 mbps = 1h 12 mins\n\nmultipart upload=> \nchunk files on client to 5mb chunk\n\nfingerprint each chunk: hash(bytes)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
