      "text": "Driver\n- id\n- ...metadata\n- status: in_ride | offline | available\n\nDriver Lock (TTL)\n- DriverId",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Driver\n- id\n- ...metadata\n- status: in_ride | offline | available\n\nDriver Lock (TTL)\n- DriverId",
