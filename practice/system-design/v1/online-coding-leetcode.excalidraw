      "updated": 1779751108706,
      "link": null,
      "locked": false,
      "text": "Core Entities\n- User \n- Problem\n- Submission\n- Competition\n- Leaderboard\n\nAPI\n- GET /problems?category={}&difficulty={}&page={}&size={} -> Problems[]\n- GET /problems/:problemId -> Problem\n- POST /problems/:problemId -> Submission\n{\n    code,\n    language,\n    competitionId?\n}\n- GET /leaderboard/:competitionId?page={}&size={} -> Leaderboard\n- ...\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Core Entities\n- User \n- Problem\n- Submission\n- Competition\n- Leaderboard\n\nAPI\n- GET /problems?category={}&difficulty={}&page={}&size={} -> Problems[]\n- GET /problems/:problemId -> Problem\n- POST /problems/:problemId -> Submission\n{\n    code,\n    language,\n    competitionId?\n}\n- GET /leaderboard/:competitionId?page={}&size={} -> Leaderboard\n- ...\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
