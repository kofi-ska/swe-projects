    },
    {
      "id": "9ObpFxHO0DIaFx3KtVMwR",
      "type": "text",
      "x": 1296.4423751831055,
      "y": 337.921875,
      "width": 63.91993713378906,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
